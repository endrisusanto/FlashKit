{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Odin By Endri-Pro",
  "version": "0.2.0",
  "identifier": "com.endri-pro.odin-clone",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Odin By Endri-Pro v0.2.0",
        "width": 800,
        "height": 650,
        "minWidth": 600,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "theme": "Dark",
        "transparent": true,
        "contentProtected": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../bin/windows/odin4.exe",
      "../bin/linux/odin4"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}